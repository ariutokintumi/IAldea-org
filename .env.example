# IAldea - Variables de Entorno (Ejemplo)

# Base de Datos
DB_PASSWORD=ialdea2026
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ialdea_db
DB_USER=admin

# Cifrado (Conmutador)
# Generar una llave de 32 bytes para AES-256
CONMUTADOR_KEY=reemplazar_con_una_llave_segura_de_32_caracteres

# API Keys (IA)
OPENAI_API_KEY=tu_openai_key
ANTHROPIC_API_KEY=tu_anthropic_key

# eVVM
EVVM_RPC_URL=https://rpc.evvm.org
EVVM_PRIVATE_KEY=tu_llave_privada_aqui

# Telegram Bot API
TELEGRAM_TOKEN=tu_telegram_bot_token

# WhatsApp Business API (Opcional)
WHATSAPP_VERIFY_TOKEN=ialdea_secret_token
WHATSAPP_ACCESS_TOKEN=tu_access_token_de_meta
WHATSAPP_PHONE_ID=tu_phone_number_id

# Orquestación LangGraph (opcional). Si está vacío, los gateways usan solo Node (router.js).
LANGGRAPH_ORCHESTRATOR_URL=http://127.0.0.1:8000

# Puente Node para LangGraph (subagentes + Postgres)
ORCHESTRATOR_BRIDGE_URL=http://127.0.0.1:3011
ORCHESTRATOR_BRIDGE_PORT=3011

# Subagentes en Docker: URL del servicio Conmutador
CONMUTADOR_URL=http://127.0.0.1:3005
